---
import "../styles/main.scss";
import { ClientRouter } from "astro:transitions";
import { siteText } from "../data/siteText";

import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

import ModalConsult from "../components/layout/ModalConsult.astro";
import ToastHost from "../components/layout/ToastHost.astro";
import StartLead from "../components/sections/StartLead.astro";
import LeadDock from "../components/forms/LeadDock.astro";

const pathname = Astro.url.pathname;
const isHome = pathname === "/";

type JsonLd = Record<string, unknown>;
type BreadcrumbItem = { name: string; href: string };

const {
  reveal = true,
  bodyClass = "",
  title,
  description,
  canonical,
  ogImage,
  ogImageAlt,
  noindex = false,
  hreflangs = [],
  breadcrumbs = [],
  jsonLd = [],
} = Astro.props as {
  reveal?: boolean;
  bodyClass?: string;
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  hreflangs?: Array<{ lang: string; href: string }>;
  breadcrumbs?: BreadcrumbItem[];
  jsonLd?: JsonLd | JsonLd[];
};

const bodyClassName = [bodyClass, isHome ? "page--home" : ""].filter(Boolean).join(" ");
const base = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL("https://teacha.pages.dev");
const siteName = siteText.seo.siteName;
const defaultTitle = siteText.seo.defaultTitle;
const defaultDescription = siteText.seo.defaultDescription;
const defaultOgImage = siteText.seo.defaultOgImage;
const contact = siteText.shared.contact;

const toAbsoluteUrl = (value: string) => {
  try {
    return new URL(value).toString();
  } catch {
    return new URL(value.replace(/^\/+/, ""), site).toString();
  }
};

const pageTitleRaw = title?.trim() ?? "";
const metaTitle = pageTitleRaw
  ? (pageTitleRaw.includes(siteName) ? pageTitleRaw : `${pageTitleRaw} | ${siteName}`)
  : defaultTitle;
const metaDescription = description?.trim() || defaultDescription;
const canonicalUrl = toAbsoluteUrl(canonical ?? pathname);
const ogImageUrl = toAbsoluteUrl(ogImage ?? defaultOgImage);
const robotsContent = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";

const alternateLinks = (hreflangs.length
  ? hreflangs
  : [
      { lang: "uk", href: canonicalUrl },
      { lang: "x-default", href: canonicalUrl },
    ]
).map((item) => ({
  hreflang: item.lang,
  href: toAbsoluteUrl(item.href),
}));

const normalizedBreadcrumbs = breadcrumbs.filter((item) => item?.name && item?.href);
const breadcrumbTrail = normalizedBreadcrumbs.length
  ? [
      { name: siteText.seo.homeBreadcrumb, href: "/" },
      ...normalizedBreadcrumbs.filter((item) => item.href !== "/" && item.href !== ""),
    ]
  : [];

const seoLinks = siteText.seo.links.map((item) => ({
  href: `${base}${item.href}`,
  label: item.label,
}));

const siteUrl = site.toString();
const clientTextJson = JSON.stringify(siteText.client).replace(/</g, "\\u003c");

const organizationSchema: JsonLd = {
  "@context": "https://schema.org",
  "@type": ["EducationalOrganization", "LocalBusiness"],
  name: siteName,
  url: siteUrl,
  image: ogImageUrl,
  logo: toAbsoluteUrl("/img/layout/logo.png"),
  email: contact.email,
  telephone: contact.phones[0].raw,
  contactPoint: [
    {
      "@type": "ContactPoint",
      contactType: "customer support",
      telephone: contact.phones[0].raw,
      areaServed: "UA",
      availableLanguage: ["uk"],
    },
  ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday",
      ],
      opens: "09:00",
      closes: "21:00",
    },
  ],
  sameAs: [
    contact.instagramUrl,
    contact.tiktokUrl,
  ],
  address: {
    "@type": "PostalAddress",
    addressCountry: "UA",
    addressLocality: contact.city,
    streetAddress: contact.street,
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 50.47026,
    longitude: 30.357656,
  },
  hasMap: contact.mapUrl,
};

const websiteSchema: JsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: siteUrl,
  inLanguage: "uk-UA",
};

const webpageSchema: JsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: metaTitle,
  description: metaDescription,
  url: canonicalUrl,
  inLanguage: "uk-UA",
  isPartOf: {
    "@type": "WebSite",
    name: siteName,
    url: siteUrl,
  },
};

const breadcrumbSchema: JsonLd | null = breadcrumbTrail.length
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbTrail.map((item, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: item.name,
        item: toAbsoluteUrl(item.href),
      })),
    }
  : null;

const customJsonLd = (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).filter(Boolean);
const jsonLdItems = [organizationSchema, websiteSchema, webpageSchema, breadcrumbSchema, ...customJsonLd]
  .filter(Boolean);
---

<!doctype html>
<html lang="uk" class="js">
  <head>
    <ClientRouter />
    <noscript>
      <style>
        {`
          html.js [data-reveal="load"] [data-reveal-item],
          html.js [data-reveal-load] [data-reveal-item]{
            opacity:1 !important;
            transform:none !important;
            transition:none !important;
          }
        `}
      </style>
    </noscript>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{metaTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="robots" content={robotsContent} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#f6efe3" />
    <link rel="icon" type="image/png" href={`${base}img/layout/logo.png`} />
    <link rel="shortcut icon" href={`${base}img/layout/logo.png`} />
    <link rel="apple-touch-icon" href={`${base}img/layout/logo.png`} />

    {
      alternateLinks.map((link) => (
        <link rel="alternate" hreflang={link.hreflang} href={link.href} />
      ))
    }

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="uk_UA" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt ?? metaTitle} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    {
      jsonLdItems.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
    <script type="application/json" id="teacha-client-text" set:html={clientTextJson}></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class={bodyClassName} {...(!reveal ? { "data-reveal-off": "" } : {})}>
    <Header />

    <main>
      <slot />
    </main>

    <nav class="visuallyHidden" aria-hidden="true" data-seo-links>
      {
        seoLinks.map((item) => (
          <a href={item.href} tabindex="-1">{item.label}</a>
        ))
      }
    </nav>

    <StartLead base={base} />
    <Footer />

    <ModalConsult />
    <ToastHost />
    <LeadDock />

    <script type="module" src={`${import.meta.env.BASE_URL}scripts/main.js`}></script>
  </body>
</html>
