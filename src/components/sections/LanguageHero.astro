---
/**
 * TeaCha website
 * Design & development: Ілля Пінчук Вадимович
 * © 2026. All rights reserved.
 */

import { siteText } from "../../data/siteText";

type TitlePart =
  | {
      text: string;
      accent?: boolean;
    }
  | {
      br: true;
    };

const {
  base,
  titleParts = [],
  subtitle = "",
  ctaText = siteText.sections.languageHero.defaultCtaText,
  className = "",
  imgSrc,
  imgAlt = siteText.sections.languageHero.defaultImageAlt,
  imgLoading = "lazy",
  imgDecoding = "async",
  imgFetchpriority = "auto",
  imgWidth = 1659,
  imgHeight = 2488,
} = Astro.props as {
  base: string;
  titleParts?: ReadonlyArray<TitlePart>;
  subtitle?: string;
  ctaText?: string;
  className?: string;
  imgSrc?: string;
  imgAlt?: string;
  imgLoading?: "lazy" | "eager";
  imgDecoding?: "sync" | "async" | "auto";
  imgFetchpriority?: "high" | "low" | "auto";
  imgWidth?: number;
  imgHeight?: number;
};

const resolvedImg = imgSrc ?? `${base}img/hero/chinese/chinese-language-hero.webp`;
const sectionClass = ["hero", "hero--lang", className].filter(Boolean).join(" ");
---

<section class={sectionClass} data-reveal="load">
  <div class="container hero__grid">
    <div class="hero__left">
      <h1 class="hero__title" data-reveal-item="1">
        <div class="hero__titleLine">
          {
            titleParts.map((part) => {
              if ("br" in part) return <br />;
              return part.accent ? (
                <span class="hero__accent">{part.text}</span>
              ) : (
                part.text
              );
            })
          }
        </div>
      </h1>

      <p class="hero__subtitle hero__subtitle--big" data-reveal-item="2">
        {subtitle}
      </p>

      <div class="hero__cta hero__cta--pill" data-reveal-item="3">
        <button class="hero__pill" type="button" data-open-modal>
          {ctaText}
        </button>
      </div>
    </div>

    <div class="hero__right" data-reveal-item="4">
      <div class="heroPhoto">
        <img
          class="heroPhoto__img"
          src={resolvedImg}
          alt={imgAlt}
          loading={imgLoading}
          decoding={imgDecoding}
          fetchpriority={imgFetchpriority}
          width={imgWidth}
          height={imgHeight}
        />
      </div>
    </div>
  </div>
</section>
