import { siteText } from "../../data/siteText";

type FactItem = {
  kind: "stat" | "text";
  value?: string;
  label?: string;
  text?: string;
  wide?: boolean;
};

const {
  items = siteText.sections.facts.items satisfies ReadonlyArray<FactItem>,
  className = "",
} = Astro.props as { items?: ReadonlyArray<FactItem>; className?: string };
---

<section class={`facts ${className}`} data-facts>
  <div class="facts__bg" aria-hidden="true"></div>

  <!-- ✅ используем общий container -->
  <div class="container">
    <h2 class="visuallyHidden">{siteText.sections.facts.heading}</h2>
    <div class="facts__grid" aria-label={siteText.sections.facts.gridAria}>
      {
        items.map((item) => (
          <article class={`facts__card ${item.wide ? "facts__card--wide" : ""}`}>
            {item.kind === "stat" ? (
              <div class="facts__stat">
                <div class="facts__value">{item.value}</div>
                <div class="facts__label">{item.label}</div>
              </div>
            ) : (
              <div class="facts__text">
                {(item.text ?? "").split("\n").map((line) => (
                  <>
                    {line}
                    <br />
                  </>
                ))}
              </div>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
