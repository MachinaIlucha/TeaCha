---
import { faqHome, faqCorporate } from "../../data/faqData.js";

const { className = "" } = Astro.props;

const path = Astro.url?.pathname ?? "/";
const isCorporate = path.startsWith("/corporate");

const items = isCorporate ? faqCorporate : faqHome;

// ✅ всегда cards
const sectionClass = `faq faq--cards ${className}`.trim();

const mid = Math.ceil(items.length / 2);
const left = items.slice(0, mid);
const right = items.slice(mid);
---

<section
  class={sectionClass}
  id="faq"
  data-faq
  data-reveal="scroll"
  tabindex="0"
>
  <div class="container">
    <div class="faq__head" data-reveal-item="1">
      <span class="brandStamp" aria-hidden="true"></span>
      <span class="handNote" aria-hidden="true">note</span>
      <h2 class="faq__mega"><span class="marker">FAQ</span></h2>
      <p class="faq__sub">
        Ми знаємо, як важливо мати чіткі відповіді на всі запитання перед
        початком навчання. У цьому розділі ви знайдете всю необхідну інформацію
        про наші курси
      </p>
    </div>

    <div class="faq__grid" data-reveal-item="2">
      <div class="faq__col">
        {
          left.map((it) => (
            <article class="faqItem" data-faq-item>
              <button class="faqItem__btn" type="button" aria-expanded="false">
                <span class="faqItem__q">{it.q}</span>
                <span class="faqItem__icon" aria-hidden="true" />
              </button>

              <div class="faqItem__panel" hidden>
                <div class="faqItem__answer" set:html={it.a} />
              </div>
            </article>
          ))
        }
      </div>

      <div class="faq__col">
        {
          right.map((it) => (
            <article class="faqItem" data-faq-item>
              <button class="faqItem__btn" type="button" aria-expanded="false">
                <span class="faqItem__q">{it.q}</span>
                <span class="faqItem__icon" aria-hidden="true" />
              </button>

              <div class="faqItem__panel" hidden>
                <div class="faqItem__answer" set:html={it.a} />
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
