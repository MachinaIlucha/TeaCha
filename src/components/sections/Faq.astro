---
/**
 * TeaCha website
 * Design & development: Ілля Пінчук Вадимович
 * © 2026. All rights reserved.
 */

import { siteText } from "../../data/siteText";

type FaqItem = { q: string; a: string };

const { className = "", items: customItems } = Astro.props as {
  className?: string;
  items?: readonly FaqItem[];
};

const path = Astro.url?.pathname ?? "/";
const isCorporate = path.startsWith("/corporate");

const items: readonly FaqItem[] = customItems
  ? customItems
  : isCorporate
    ? siteText.sections.faq.items.corporate
    : siteText.sections.faq.items.home;

// ✅ всегда cards
const sectionClass = `faq faq--cards ${className}`.trim();

const mid = Math.ceil(items.length / 2);
const left = items.slice(0, mid);
const right = items.slice(mid);

const plainText = (value: string) =>
  value
    .replace(/<br\s*\/?>/gi, " ")
    .replace(/<[^>]+>/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: plainText(item.q),
    acceptedAnswer: {
      "@type": "Answer",
      text: plainText(item.a),
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section
  class={sectionClass}
  id="faq"
  data-faq
  data-reveal="scroll"
  tabindex="0"
>
  <div class="container">
    <div class="faq__head" data-reveal-item="1">
      <h2 class="faq__mega">{siteText.sections.faq.title}</h2>
      <p class="faq__sub">{siteText.sections.faq.subtitle}</p>
    </div>

    <div class="faq__grid" data-reveal-item="2">
      <div class="faq__col">
        {
          left.map((it, idx) => {
            const btnId = `faq-btn-l-${idx + 1}`;
            const panelId = `faq-panel-l-${idx + 1}`;

            return (
              <article class="faqItem" data-faq-item>
                <button
                  class="faqItem__btn"
                  id={btnId}
                  type="button"
                  aria-expanded="false"
                  aria-controls={panelId}
                >
                  <span class="faqItem__q">{it.q}</span>
                  <span class="faqItem__icon" aria-hidden="true" />
                </button>

                <div
                  class="faqItem__panel"
                  id={panelId}
                  role="region"
                  aria-labelledby={btnId}
                  hidden
                >
                  <div class="faqItem__answer" set:html={it.a} />
                </div>
              </article>
            );
          })
        }
      </div>

      <div class="faq__col">
        {
          right.map((it, idx) => {
            const btnId = `faq-btn-r-${idx + 1}`;
            const panelId = `faq-panel-r-${idx + 1}`;

            return (
              <article class="faqItem" data-faq-item>
                <button
                  class="faqItem__btn"
                  id={btnId}
                  type="button"
                  aria-expanded="false"
                  aria-controls={panelId}
                >
                  <span class="faqItem__q">{it.q}</span>
                  <span class="faqItem__icon" aria-hidden="true" />
                </button>

                <div
                  class="faqItem__panel"
                  id={panelId}
                  role="region"
                  aria-labelledby={btnId}
                  hidden
                >
                  <div class="faqItem__answer" set:html={it.a} />
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
