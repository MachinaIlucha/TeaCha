---
type ProcessStep = { text: string };

const {
  titleTop = "ПРОЦЕС",
  titleBottom = "НАВЧАННЯ",
  accent = "bottom", // "bottom" | "top"
  steps = [
    { text: "Знайомство з <br/>вашим запитом" },
    { text: "Оцінка вашого рівня та <br/>підбір зручного формату навчання " },
    { text: "Створення індивідуального <br/>навчального плану" },
    { text: "Початок<br/>навчання" },
    { text: "Щомісячна звітність <br/>про ваші успіхи" },
  ] satisfies ProcessStep[],
  footnote = "* Кожна корпоративна група отримує план курсу, його опис, перелік лексичних та граматичних тем",
} = Astro.props as {
  titleTop?: string;
  titleBottom?: string;
  accent?: "bottom" | "top";
  steps?: ProcessStep[];
  footnote?: string;
};
---

<section class="process" data-process>
  <div class="container">
    <header
      class={`sectionTitle sectionTitle--center ${
        accent === "top" ? "sectionTitle--accentTop" : "sectionTitle--accentBottom"
      }`}
      data-reveal="scroll"
    >
      <h2 class="sectionTitle__line sectionTitle__line--a" data-reveal-item="1">
        {titleTop}
      </h2>
      <div class="sectionTitle__line sectionTitle__line--b" data-reveal-item="2">
        {titleBottom}
      </div>
    </header>

    <ol class="process__timeline" aria-label="Процес навчання">
      {
        steps.map((s, idx) => (
          <li class="process__item">
            <div class="process__content" set:html={s.text} />
            <div class="process__node">
              <span class="process__num">{idx + 1}</span>
            </div>
          </li>
        ))
      }
    </ol>

    <!-- <p class="process__note">{footnote}</p> -->
  </div>

  <script type="module" src="/scripts/ui/process.js"></script>
</section>
