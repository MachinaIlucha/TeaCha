---
/**
 * TeaCha website
 * Design & development: Ілля Пінчук Вадимович
 * © 2026. All rights reserved.
 */

import { siteText } from "../../data/siteText";
import { resolveAssetPath } from "../../data/assetMap";

const reviewText = siteText.sections.reviews;

const {
  titleTop = reviewText.titleTop,
  titleBottom = reviewText.titleBottom,
  accent = "bottom", // "bottom" | "top"
  className = "",
} = Astro.props as {
  titleTop?: string;
  titleBottom?: string;
  accent?: "bottom" | "top";
  className?: string;
};

const accentClass = accent === "top" ? "sectionTitle--accentTop" : "";

const normalizeBadge = (badge: string): string => {
  const lower = badge.toLowerCase();
  if (lower.includes("english")) return "english";
  if (lower.includes("chinese")) return "chinese";

  return badge
    .split(/[\u2022•·|-]/)[0]
    .trim();
};

type Review = {
  name: string;
  badge: string;
  request: string;
  pointA: { label: string; date: string; level: string; text: string };
  pointB: { label: string; date: string; level: string; text: string };
  quote: string;
  img: string;
};

const reviews: Review[] = reviewText.list.map((item) => ({
  ...item,
  badge: normalizeBadge(item.badge),
  img: resolveAssetPath(item.img),
}));

const reviewsSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: reviewText.schemaName,
  itemListElement: reviews.map((review, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Review",
      inLanguage: "uk-UA",
      author: {
        "@type": "Person",
        name: review.name,
      },
      reviewBody: review.quote,
      itemReviewed: {
        "@type": "EducationalOrganization",
        name: "TeaCha",
        url: "https://teacha.com.ua/",
      },
    },
  })),
};

const first = reviews[0];
---

<script type="application/ld+json" set:html={JSON.stringify(reviewsSchema)} />

<section class={`r2 ${className}`} id="reviews" data-r2 data-reveal="scroll" tabindex="0">
  <div class="container" data-reveal-item="1">
    <div class="r2__head" data-reveal-item="2">
      <header
        class={`sectionTitle sectionTitle--center sectionTitle--inline ${accentClass}`}
        data-reveal="scroll"
      >
        <h2
          class="sectionTitle__line sectionTitle__line--a"
          data-reveal-item="1"
        >
          {titleTop}
        </h2>
        <div
          class="sectionTitle__line sectionTitle__line--b"
          data-reveal-item="2"
        >
          {titleBottom}
        </div>
      </header>

      <div class="r2HeadNav">
        <button
          class="r2__btn"
          type="button"
          data-r2-prev
          aria-label={reviewText.prevAriaLabel}
        >
          ←
        </button>

        <button
          class="r2__btn"
          type="button"
          data-r2-next
          aria-label={reviewText.nextAriaLabel}
        >
          →
        </button>
      </div>
    </div>

    <div class="r2__layout">
      <article class="r2Card" aria-live="polite" data-reveal-item="3">
        <div class="r2Media">
          <img
            class="r2Media__img r2Layer is-front"
            data-r2-front-img
            src={first.img}
            alt={`${reviewText.photoAltPrefix}${first.name}`}
            loading="lazy"
            decoding="async"
            width="960"
            height="1280"
          />
          <img
            class="r2Media__img r2Layer is-back"
            data-r2-back-img
            alt=""
            loading="lazy"
            decoding="async"
            width="960"
            height="1280"
          />
        </div>

        <div class="r2Info">
          <div class="r2TextStack">
            <!-- FRONT -->
            <div class="r2Layer is-front" data-r2-front>
              <div class="r2Top">
                <h3 class="r2Name" data-r2-front-name>{first.name}</h3>
                <span class="r2Badge" data-r2-front-badge>{first.badge}</span>
              </div>

              <div class="r2Body">
                <p class="r2Row">
                  <strong>{reviewText.requestLabel}</strong>
                  <span data-r2-front-request>{first.request}</span>
                </p>

                <p class="r2Row">
                  <strong data-r2-front-a-label>{first.pointA.label}:</strong>
                  <span class="r2Meta" data-r2-front-a-meta
                    >{first.pointA.date} • {first.pointA.level}</span
                  >
                  <span data-r2-front-a-text>{first.pointA.text}</span>
                </p>

                <p class="r2Row">
                  <strong data-r2-front-b-label>{first.pointB.label}:</strong>
                  <span class="r2Meta" data-r2-front-b-meta
                    >{first.pointB.date} • {first.pointB.level}</span
                  >
                  <span data-r2-front-b-text>{first.pointB.text}</span>
                </p>
              </div>

              <div class="r2Quote">
                <div class="r2Quote__mark" aria-hidden="true">“</div>
                <p class="r2Quote__text" data-r2-front-quote>{first.quote}</p>
              </div>
            </div>

            <!-- BACK (пустой, JS заполнит) -->
            <div class="r2Layer is-back" data-r2-back></div>
          </div>
        </div>
      </article>
    </div>
  </div>

  <script
    type="application/json"
    data-r2-json
    set:html={JSON.stringify(reviews)}
  />
</section>
