---
/**
 * TeaCha website
 * Design & development: Ілля Пінчук Вадимович
 * © 2026. All rights reserved.
 */

const base = import.meta.env.BASE_URL;

const {
  titleTop = "ВІД",
  titleBottom = "ГУКИ",
  accent = "bottom", // "bottom" | "top"
  className = "",
} = Astro.props as {
  titleTop?: string;
  titleBottom?: string;
  accent?: "bottom" | "top";
  className?: string;
};

const accentClass = accent === "top" ? "sectionTitle--accentTop" : "";

type Review = {
  name: string;
  badge: string;
  request: string;
  pointA: { label: string; date: string; level: string; text: string };
  pointB: { label: string; date: string; level: string; text: string };
  quote: string;
  img: string;
};

const reviews: Review[] = [
  {
    name: "ВʼЯЧЕСЛАВ",
    badge: "english • case",
    request:
      "Підвищити рівень англійської для роботи та впевненого спілкування в іноземному середовищі.",
    pointA: {
      label: "Точка А",
      date: "Липень 2024 року",
      level: "Рівень A1+",
      text: "Може будувати примітивні речення англійською. Знає теперішній час. Непогано орієнтується в словах.",
    },
    pointB: {
      label: "Точка Б",
      date: "Вересень 2025 року",
      level: "Рівень B1+",
      text: "Може будувати складні речення з лексикою B1–B2, вільно володіє 7 часами та впевнено орієнтується в граматиці. Працює в іноземній компанії, легко комунікує з колегами.",
    },
    quote:
      "Я дуже задоволений навчанням у школі англійської мови TEACHA. Викладачі працюють на результат, заняття проходять у дружній і комфортній атмосфері, що допомагає зняти мовний бар’єр. Особливо ціную індивідуальний підхід і підтримку вчителя. Завдяки TEACHA я значно покращив англійську та став упевненішим у спілкуванні. Рекомендую всім, хто шукає якісне навчання!",
    img: `${base}img/review-1.jpg`,
  },
  {
    name: "НАТАЛІЯ",
    badge: "chinese • case",
    request:
      "Допомогти доньці впевнено вивчати китайську мову та отримати видимий результат за короткий час.",
    pointA: {
      label: "Точка А",
      date: "Вересень 2023 року",
      level: "Рівень A1",
      text: "Вікторія вміє складати елементарні речення та писати базові ієрогліфи.",
    },
    pointB: {
      label: "Точка Б",
      date: "Січень 2026 року",
      level: "Рівень B1",
      text: "Чітко висловлює свою думку, підтримує розмову на різні теми, дивиться відео та влоги китайською, пише тексти від руки.",
    },
    quote:
      "Дуже дякую TeaCha! Донька з великим задоволенням ходить на заняття з китайської мови. Подача матеріалу і майстерність вчителя — і вивчення мови йде дуже легко!!!! А головне — за короткий час гарний результат!!!! Дуже-дуже рекомендую!!!!",
    img: `${base}img/review-2.jpg`,
  },
  {
    name: "АНЯ",
    badge: "english • nmt",
    request: "Підготовка до НМТ та впевнений вступ до омріяного університету.",
    pointA: {
      label: "Точка А",
      date: "Вересень 2022",
      level: "Рівень B2",
      text: "Вільно виражає свою думку, може взяти участь в обговоренні та дебатах, добре орієнтується в граматиці.",
    },
    pointB: {
      label: "Точка Б",
      date: "Травень 2023",
      level: "НМТ / вступ",
      text: "Здача НМТ, вступ до омріяного університету КПІ ім. Ігоря Сікорського.",
    },
    quote:
      "Добрий день! Щиро дякую вам за всі заняття, які ми мали разом: ви багато чому мене навчили, допомогли з підготовкою, завжди дарували приємний настрій і дали змогу вступити туди, куди я хотіла - величезне дякую!",
    img: `${base}img/review-3.jpg`,
  },
  {
    name: "ОЛЕНА",
    badge: "english • case",
    request:
      "Подолати мовний бар’єр, системно підтягнути граматику та впевнено говорити на різні теми.",
    pointA: {
      label: "Точка А",
      date: "Лютий 2022",
      level: "Рівень A1",
      text: "Памʼятає базові вирази зі школи/університету, може дати відповідь на прості питання, знає 3 граматичні часи.",
    },
    pointB: {
      label: "Точка Б",
      date: "Грудень 2024",
      level: "Рівень B1",
      text: "Висловлює свою думку на різноманітні теми, вчить профільну англійську, розуміє мову на слух, знає 7 граматичних часів.",
    },
    quote:
      "Це мій 105 підхід до вивчення англійської і лише перший вдалий, бо насправді бачу і відчуваю результат. Заняття цікаві і їх хочеться відвідувати, а не оце «треба». Завжди дуже прискіпливо до всього відношусь і як людина, яка трохи розуміється на навчанні персоналу, можу з впевненістю сказати, що Дарина, як то кажуть, викладач від Бога. Завжди все чітко, зрозуміло, структуровано і головне доведено майже до ідеалу ❤️",
    img: `${base}img/review-4.jpg`,
  },
  {
    name: "ЮЛІЯ",
    badge: "english • case",
    request:
      "Швидко та якісно підготуватись до співбесіди в іноземну компанію та впевнено проходити інтервʼю англійською.",
    pointA: {
      label: "Точка А",
      date: "Березень 2024",
      level: "Рівень A2",
      text: "Висловлює свою думку, вміє підтримати розмову на базові теми, непогано орієнтується у граматиці, споживає багато англомовного контенту.",
    },
    pointB: {
      label: "Точка Б",
      date: "Квітень 2025",
      level: "Рівень B1+",
      text: "Суттєво збільшила словниковий запас, підтягнула бізнес англійську, покращила розуміння мови на слух, успішно пройшла співбесіду в іноземну компанію.",
    },
    quote:
      "Завдяки вашому мовному центру я швидко та якісно підготувалась до співбесіди на роботу своєї мрії 😍 Викладач англійської — справжній професіонал, який знайде підхід до будь-якої людини з будь-яким рівнем знань 🥰",
    img: `${base}img/review-5.jpg`,
  },
];

const first = reviews[0];
---

<section class={`r2 ${className}`} id="reviews" data-r2 data-reveal="scroll" tabindex="0">
  <div class="container" data-reveal-item="1">
    <div class="r2__head" data-reveal-item="2">
      <header
        class={`sectionTitle sectionTitle--center sectionTitle--inline sectionTitle--stamped ${accentClass}`}
        data-reveal="scroll"
      >
        <span class="brandStamp" aria-hidden="true"></span>
        <span class="handNote" aria-hidden="true">case</span>
        <h2
          class="sectionTitle__line sectionTitle__line--a"
          data-reveal-item="1"
        >
          <span class="marker marker--round">{titleTop}</span>
        </h2>
        <div
          class="sectionTitle__line sectionTitle__line--b"
          data-reveal-item="2"
        >
          {titleBottom}
        </div>
      </header>

      <div class="r2HeadNav">
        <button
          class="r2__btn"
          type="button"
          data-r2-prev
          aria-label="Попередній відгук"
        >
          ←
        </button>

        <button
          class="r2__btn"
          type="button"
          data-r2-next
          aria-label="Наступний відгук"
        >
          →
        </button>
      </div>
    </div>

    <div class="r2__layout">
      <article class="r2Card" aria-live="polite" data-reveal-item="3">
        <div class="r2Media">
          <img
            class="r2Media__img r2Layer is-front"
            data-r2-front-img
            src={first.img}
            alt={`Фото: ${first.name}`}
            loading="lazy"
            width="960"
            height="1280"
          />
          <img
            class="r2Media__img r2Layer is-back"
            data-r2-back-img
            alt=""
            loading="lazy"
            width="960"
            height="1280"
          />
        </div>

        <div class="r2Info">
          <div class="r2TextStack">
            <!-- FRONT -->
            <div class="r2Layer is-front" data-r2-front>
              <div class="r2Top">
                <h3 class="r2Name" data-r2-front-name>{first.name}</h3>
                <span class="r2Badge" data-r2-front-badge>{first.badge}</span>
              </div>

              <div class="r2Body">
                <p class="r2Row">
                  <strong>Запит:</strong>
                  <span data-r2-front-request>{first.request}</span>
                </p>

                <p class="r2Row">
                  <strong data-r2-front-a-label>{first.pointA.label}:</strong>
                  <span class="r2Meta" data-r2-front-a-meta
                    >{first.pointA.date} • {first.pointA.level}</span
                  >
                  <span data-r2-front-a-text>{first.pointA.text}</span>
                </p>

                <p class="r2Row">
                  <strong data-r2-front-b-label>{first.pointB.label}:</strong>
                  <span class="r2Meta" data-r2-front-b-meta
                    >{first.pointB.date} • {first.pointB.level}</span
                  >
                  <span data-r2-front-b-text>{first.pointB.text}</span>
                </p>
              </div>

              <div class="r2Quote">
                <div class="r2Quote__mark" aria-hidden="true">“</div>
                <p class="r2Quote__text" data-r2-front-quote>{first.quote}</p>
              </div>
            </div>

            <!-- BACK (пустой, JS заполнит) -->
            <div class="r2Layer is-back" data-r2-back></div>
          </div>
        </div>
      </article>
    </div>
  </div>

  <script
    type="application/json"
    data-r2-json
    set:html={JSON.stringify(reviews)}
  />
</section>
