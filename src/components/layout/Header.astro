 */

import SocialLink from "../ui/SocialLink.astro";
import { siteText } from "../../data/siteText";
import { resolveAssetPath } from "../../data/assetMap";

const base = import.meta.env.BASE_URL;
const contact = siteText.shared.contact;

const normalizePath = (value: string) => {
  const normalized = value.replace(/\/+$/, "");
  return normalized === "" ? "/" : normalized;
};

const currentPath = normalizePath(Astro.url.pathname);
const navLinks = siteText.navigation.links.map((link) => {
  const href = `${base}${link.href}`;
  const linkPath = normalizePath(new URL(href, Astro.url).pathname);
  return {
    ...link,
    href,
    isActive: currentPath === linkPath || currentPath.startsWith(linkPath + "/"),
  };
});
---

<header class="topbar" id="top">
  <div class="container topbar__row">
    <a class="brand" href={base} aria-label={siteText.shared.homeAriaLabel}>
      <img class="brand__logo" src={resolveAssetPath("img/layout/logo.png")} alt={siteText.shared.brandName} />
      <span class="brand__word">
        <span class="tea">Tea</span><span class="cha">Cha</span>
      </span>
    </a>

    <nav class="nav" aria-label={siteText.navigation.ariaLabel}>
      <button
        class="nav__burger"
        data-burger
        aria-label={siteText.navigation.burgerAriaLabel}
        aria-expanded="false"
        aria-controls="topbar-panel"
      >
        <span></span><span></span><span></span>
      </button>

      <div class="nav__right" id="topbar-panel" data-nav-panel aria-hidden="true">
        <div class="nav__social">
          <SocialLink
            href={contact.instagramUrl}
            network="instagram"
            ariaLabel={siteText.shared.social.instagramLabel}
          />
          <SocialLink
            href={contact.tiktokUrl}
            network="tiktok"
            ariaLabel={siteText.shared.social.tiktokLabel}
          />
        </div>

        <div class="nav__links">
          {
            navLinks.map((link) => (
              <a
                class={`pill ${link.isActive ? "is-active" : ""}`}
                href={link.href}
                aria-current={link.isActive ? "page" : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </nav>
  </div>
</header>
