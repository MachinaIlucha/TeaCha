---
/**
 * TeaCha website
 * Design & development: Ілля Пінчук Вадимович
 * © 2026. All rights reserved.
 */

import PrivacyConsent from "../forms/PrivacyConsent.astro";

const base = import.meta.env.BASE_URL;
---

<footer class="footer" id="contacts">
  <div class="container footer__hero">
    <div class="footer__brandLine">
      <img class="footer__logo" src={`${base}img/layout/logo.png`} alt="TeaCha" />
      <div class="footer__name">
        <span class="tea">Tea</span><span class="cha">Cha</span>
      </div>
    </div>
  </div>

  <div class="container footer__info">
    <div class="footer__infoRow">
      <div class="footer__contactsRow">
        <span class="footer__infoLabel">КОНТАКТИ</span>
        <span class="footer__text">+38 (063) 460-21-20</span>
        <span class="footer__text">+38 (067) 362-63-64</span>
        <span class="footer__text">teachaschoolkyiv@gmail.com</span>
      </div>

      <div class="footer__linksRow">
        <a
          class="footer__link"
          href={`${base}docs/dogovir-publichnoi-oferty.pdf`}
          target="_blank"
          rel="noopener"
        >
          ДОГОВІР ПУБЛІЧНОЇ ОФЕРТИ
        </a>

        <a
          class="footer__link"
          href={`${base}docs/polityka-konfidentsiinosti.pdf`}
          target="_blank"
          rel="noopener"
        >
          ПОЛІТИКА КОНФІДЕНЦІЙНОСТІ
        </a>
      </div>

      <div class="footer__social">
        <a
          class="iconBtn"
          href="https://www.instagram.com/teacha_english_chinese?igsh=MW15MzJpdmVqemRidg=="
          aria-label="Instagram"
          target="_blank"
          rel="noopener"
        >
          <img class="iconBtn__img" src={`${base}img/layout/ig.png`} alt="" />
        </a>
        <a
          class="iconBtn"
          href="https://www.tiktok.com/@school.teacha?_r=1&_t=ZM-92xtLcPpblU"
          aria-label="TikTok"
          target="_blank"
          rel="noopener"
        >
          <img class="iconBtn__img" src={`${base}img/layout/tiktok.png`} alt="" />
        </a>
      </div>
    </div>
  </div>

  <div class="container footer__main">
    <div class="footer__formCard">
      <div class="footerForm__head">
        <span class="footerForm__title">Запишись на пробний урок</span>
        <img
          class="footerForm__icon"
          src={`${base}img/forms/icon-handwrite-black.png`}
          alt=""
          aria-hidden="true"
          loading="lazy"
        />
      </div>

      <form
        class="footerForm"
        id="footer-lead-form"
        action="#"
        method="post"
      >
        <div class="footerForm__fields">
          <label class="footerForm__field">
            <span class="footerForm__label">ІМ'Я</span>
            <input
              class="footerForm__input"
              name="name"
              type="text"
              autocomplete="name"
              required
            />
          </label>

          <label class="footerForm__field">
            <span class="footerForm__label">ТЕЛЕФОН АБО НІК TELEGRAM</span>
            <input
              class="footerForm__input"
              name="contact"
              type="text"
              autocomplete="tel"
              required
            />
          </label>
        </div>

        <div class="footerForm__consent">
          <PrivacyConsent className="consent--light" />
        </div>

        <div class="footerForm__cta">
          <button class="footerForm__submit" type="submit">
            ХОЧУ ПРОБНЕ ЗАНЯТТЯ
          </button>
        </div>
      </form>

    </div>
  </div>

  <div class="footer__bottom">
    <span>© 2026 TeaCha. Усі права захищені.</span>
    <span>
      Дизайн та розробка —
      <a
        href="https://www.linkedin.com/in/illia-pinchuk/"
        class="footer__author"
        target="_blank"
        rel="noopener"
      >
        Ілля Пінчук
      </a>
    </span>
  </div>
</footer>
