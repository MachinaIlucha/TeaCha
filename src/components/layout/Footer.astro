 * © 2026. All rights reserved.
 */

import PrivacyConsent from "../forms/PrivacyConsent.astro";
import SocialLink from "../ui/SocialLink.astro";
import { siteText } from "../../data/siteText";
import { resolveAssetPath } from "../../data/assetMap";

const base = import.meta.env.BASE_URL;
const contact = siteText.shared.contact;
const docs = siteText.shared.docs;
const forms = siteText.shared.forms;
const footerText = siteText.shared.footer;
---

<footer class="footer" id="contacts">
  <div class="container footer__hero">
    <div class="footer__brandLine">
      <img class="footer__logo" src={resolveAssetPath("img/layout/logo.png")} alt={siteText.shared.brandName} />
      <div class="footer__name">
        <span class="tea">Tea</span><span class="cha">Cha</span>
      </div>
    </div>
  </div>

  <div class="container footer__info">
    <h2 class="visuallyHidden">{footerText.contactsTitle}</h2>
    <div class="footer__infoRow">
      <div class="footer__contactsRow">
        <span class="footer__infoLabel">{footerText.contactsLabel}</span>
        {
          contact.phones.map((phone) => (
            <span class="footer__text">{phone.label}</span>
          ))
        }
        <span class="footer__text">{contact.email}</span>
      </div>

      <div class="footer__rightCol">
        <div class="footer__linksRow">
          <a
            class="footer__link"
            href={`${base}${docs.offerFile}`}
            target="_blank"
            rel="noopener"
          >
            {docs.offerLabel}
          </a>

          <a
            class="footer__link"
            href={`${base}${docs.privacyFile}`}
            target="_blank"
            rel="noopener"
          >
            {docs.privacyLabel}
          </a>
        </div>

        <div class="footer__social">
          <SocialLink
            href={contact.instagramUrl}
            network="instagram"
            ariaLabel={siteText.shared.social.instagramLabel}
            size="sm"
          />
          <SocialLink
            href={contact.tiktokUrl}
            network="tiktok"
            ariaLabel={siteText.shared.social.tiktokLabel}
            size="sm"
          />
        </div>
      </div>
    </div>
  </div>

  <div class="container footer__main">
    <div class="footer__formCard">
      <div class="footerForm__head">
        <span class="footerForm__title">{forms.trialLeadTitle}</span>
        <img
          class="footerForm__icon"
          src={resolveAssetPath("img/forms/icon-handwrite-black.png")}
          alt=""
          aria-hidden="true"
          loading="lazy"
        />
      </div>

      <form
        class="footerForm"
        id="footer-lead-form"
        action="#"
        method="post"
      >
        <div class="footerForm__fields">
          <label class="footerForm__field">
            <span class="footerForm__label">{forms.nameLabel}</span>
            <input
              class="footerForm__input"
              name="name"
              type="text"
              autocomplete="name"
              required
            />
          </label>

          <label class="footerForm__field">
            <span class="footerForm__label">{forms.contactLabel}</span>
            <input
              class="footerForm__input"
              name="contact"
              type="text"
              autocomplete="tel"
              required
            />
          </label>
        </div>

        <div class="footerForm__consent">
          <PrivacyConsent className="consent--light" />
        </div>

        <div class="footerForm__cta">
          <button class="footerForm__submit" type="submit">
            {forms.trialButton}
          </button>
        </div>
      </form>

    </div>
  </div>

  <div class="footer__bottom">
    <span>{footerText.copyright}</span>
    <span>
      {footerText.designPrefix} —
      <a
        href={footerText.authorUrl}
        class="footer__author"
        target="_blank"
        rel="noopener"
      >
        {footerText.authorName}
      </a>
    </span>
  </div>
</footer>
