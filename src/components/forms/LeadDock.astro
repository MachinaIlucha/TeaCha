const base = import.meta.env.BASE_URL;
const { hidden = false } = Astro.props;
---

<div
  class="leadDock"
  id="lead-dock"
  data-reveal="off"
  aria-hidden={hidden ? "true" : "false"}
  style={hidden ? "display:none" : ""}
>
  <div class="container leadDock__inner">
    <form
      class="leadDock__form"
      id="lead-dock-form"
      action="#"
      method="post"
      novalidate
    >
      <div class="leadDock__intro">
        <img
          class="leadDock__icon"
          src={`${base}img/icon-handwrite-black.png`}
          alt=""
          loading="lazy"
          aria-hidden="true"
        />
        <div class="leadDock__introText">Запишись на пробний урок</div>
      </div>

      <div class="leadDock__fields">
        <label class="leadDock__field floatField">
          <input
            class="fieldInput leadDock__input floatField__input"
            name="name"
            type="text"
            placeholder=" "
            autocomplete="name"
            required
          />
          <span class="floatField__label">ІМʼЯ</span>
        </label>

        <label class="leadDock__field floatField">
          <input
            class="fieldInput leadDock__input floatField__input"
            name="contact"
            type="text"
            placeholder=" "
            autocomplete="tel"
            required
          />
          <span class="floatField__label">ТЕЛЕФОН АБО НІК TELEGRAM</span>
        </label>
      </div>

      <button class="leadDock__btn" type="submit">
        <span class="leadDock__btnText">ХОЧУ ПРОБНЕ ЗАНЯТТЯ</span>
        <span class="leadDock__btnIcon" aria-hidden="true">
          <img
            src={`${base}img/chinese-scroll.png`}
            alt=""
            loading="lazy"
            decoding="async"
          />
        </span>
      </button>
    </form>
  </div>
</div>
