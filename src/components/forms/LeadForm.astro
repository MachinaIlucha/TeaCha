 * © 2026. All rights reserved.
 */

import { siteText } from "../../data/siteText";

const base = import.meta.env.BASE_URL;
const { id = null, className = "" } = Astro.props;
const forms = siteText.shared.forms;
const docs = siteText.shared.docs;
---

<form class={className} id={id}>
  <input
    type="text"
    name="name"
    placeholder={forms.namePlaceholder}
    required
  />

  <input
    type="text"
    name="contact"
    placeholder={forms.contactPlaceholder}
    required
  />

  <label class="price-consent">
    <input
      class="price-consent__check"
      type="checkbox"
      name="consent"
      required
    />

    <span class="price-consent__box" aria-hidden="true"></span>

    <span class="price-consent__text">
      {forms.consentText}
      <a
        href={`${base}${docs.privacyFile}`}
        target="_blank"
        rel="noopener"
      >
        {forms.consentLinkText}
      </a>
    </span>
  </label>

  <button type="submit" class="modal__submit">
    {forms.submitButton}
  </button>
</form>
