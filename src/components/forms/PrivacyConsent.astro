import { siteText } from "../../data/siteText";

const base = import.meta.env.BASE_URL;
const forms = siteText.shared.forms;
const docs = siteText.shared.docs;

const {
  className = "",
  inputClass = "consent__check",
  required = true,
  invalidMessage = forms.consentInvalidMessage
} = Astro.props;
---

<label class={`consent ${className}`}>
  <input
    class={inputClass}
    type="checkbox"
    name="consent"
    {...(required ? { required: true } : {})}
    oninvalid={`this.setCustomValidity('${invalidMessage}')`}
    onchange="this.setCustomValidity('')"
  />

  <span class="consent__box" aria-hidden="true"></span>

  <span class="consent__text">
    {forms.consentText}
    <a
      href={`${base}${docs.privacyFile}`}
      target="_blank"
      rel="noopener"
    >
      {forms.consentLinkText}
    </a>
  </span>
</label>
