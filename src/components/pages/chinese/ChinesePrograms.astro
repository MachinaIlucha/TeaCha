 * Design & development: Ілля Пінчук Вадимович
 * © 2026. All rights reserved.
 */

import { siteText } from "../../../data/siteText";
import beginnersIcon from "../../../assets/img/chinese/programs/teacha-chinese-course-beginners-icon.png";
import hskIcon from "../../../assets/img/chinese/programs/teacha-hsk-preparation-course-icon.png";
import kidsIcon from "../../../assets/img/chinese/programs/teacha-chinese-course-kids-teens-icon.png";
import businessIcon from "../../../assets/img/chinese/programs/teacha-business-chinese-course-icon.png";
import conversationIcon from "../../../assets/img/chinese/programs/teacha-conversational-chinese-course-icon.png";

const { className = "" } = Astro.props;
const base = import.meta.env.BASE_URL;
const sectionClass = ["cnPrograms", className].filter(Boolean).join(" ");
const text = siteText.sections.chinesePrograms;
const programIcons = {
  beginners: beginnersIcon,
  hsk: hskIcon,
  kids: kidsIcon,
  business: businessIcon,
  conversation: conversationIcon,
} as const;
---

<section class={sectionClass} id="program" data-reveal="scroll">
  <div class="container">
    <header
      class="sectionTitle sectionTitle--center sectionTitle--accentBottom"
      data-reveal="scroll"
    >
      <h2 class="sectionTitle__line sectionTitle__line--a" data-reveal-item="1">
        {text.titleTop}
      </h2>
      <div class="sectionTitle__line sectionTitle__line--b" data-reveal-item="2">
        {text.titleBottom}
      </div>
    </header>

    <p class="cnPrograms__intro" data-reveal-item="3">{text.subtitle}</p>

    <div class="cnPrograms__grid" data-reveal-item="4">
      {
        text.items.map((item) => {
          const icon = programIcons[item.icon as keyof typeof programIcons];

          return (
          <a class="cnPrograms__card" href={`${base}${item.href}`}>
            <div class="cnPrograms__cardInner">
              <div class="cnPrograms__head">
                <div class="cnPrograms__icon">
                  <img
                    class="cnPrograms__iconImage"
                    src={icon.src}
                    alt={item.iconAlt}
                    loading="lazy"
                    decoding="async"
                    width={icon.width}
                    height={icon.height}
                  />
                </div>

                <div class="cnPrograms__copy">
                  <h3 class="cnPrograms__title">{item.title}</h3>
                  <p class="cnPrograms__text">{item.text}</p>
                </div>
              </div>

              <div class="cnPrograms__footer">
                <span class="cnPrograms__cta heroPill">
                  <span>{text.ctaLabel}</span>
                  <span class="cnPrograms__ctaArrow" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path
                        d="M5 12h14M13 6l6 6-6 6"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </span>
              </div>
            </div>
          </a>
          );
        })
      }
    </div>
  </div>
</section>
