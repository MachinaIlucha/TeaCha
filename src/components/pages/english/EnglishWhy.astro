---
/**
 * TeaCha website
 * Design & development: Ілля Пінчук Вадимович
 * © 2026. All rights reserved.
 */

import { siteText } from "../../../data/siteText";

const { className = "" } = Astro.props;
const sectionClass = ["enWhy", className].filter(Boolean).join(" ");
const text = siteText.sections.englishWhy;
---

<section class={sectionClass} data-reveal="scroll">
  <div class="container">
    <header
      class="sectionTitle sectionTitle--center sectionTitle--accentBottom"
      data-reveal="scroll"
    >
      <h2 class="sectionTitle__line sectionTitle__line--a" data-reveal-item="1">
        {text.titleTop}
      </h2>
      <div class="sectionTitle__line sectionTitle__line--b" data-reveal-item="2">
        {text.titleBottom}
      </div>
    </header>

    <div class="enGrid" data-reveal-item="3">
      <article class="enCard">
        <span class="enCard__icon" aria-hidden="true">
          <!-- pin -->
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
            <path d="M12 22s7-4.5 7-11a7 7 0 10-14 0c0 6.5 7 11 7 11z" stroke="currentColor" stroke-width="2"/>
            <path d="M12 11.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5z" stroke="currentColor" stroke-width="2"/>
          </svg>
        </span>
        <div class="enCard__text">{text.items[0]}</div>
      </article>

      <article class="enCard">
        <span class="enCard__icon" aria-hidden="true">
          <!-- clock -->
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
            <path d="M12 22a10 10 0 110-20 10 10 0 010 20z" stroke="currentColor" stroke-width="2"/>
            <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </span>
        <div class="enCard__text">{text.items[1]}</div>
      </article>

      <article class="enCard">
        <span class="enCard__icon" aria-hidden="true">
          <!-- graduation cap -->
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
            <path d="M2 9l10-5 10 5-10 5L2 9z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            <path d="M6 11v5c0 .8 2.7 3 6 3s6-2.2 6-3v-5" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
          </svg>
        </span>
        <div class="enCard__text">{text.items[2]}</div>
      </article>

      <article class="enCard">
        <span class="enCard__icon" aria-hidden="true">
          <!-- rocket -->
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
            <path d="M14 4c3 0 6 3 6 6-2 1-4 2-6 2l-4 4-3 1 1-3 4-4c0-2 1-4 2-6z"
              stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            <path d="M9 15l-2 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </span>
        <div class="enCard__text">
          {text.items[3]}
        </div>
      </article>

      <article class="enCard">
        <span class="enCard__icon" aria-hidden="true">
          <!-- plan -->
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
            <path d="M7 3h10v18H7V3z" stroke="currentColor" stroke-width="2"/>
            <path d="M9 7h6M9 11h6M9 15h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </span>
        <div class="enCard__text">{text.items[4]}</div>
      </article>

      <article class="enCard">
        <span class="enCard__icon" aria-hidden="true">
          <!-- checklist -->
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
            <path d="M7 4h14v16H7V4z" stroke="currentColor" stroke-width="2"/>
            <path d="M3 7l1 1 2-2M3 12l1 1 2-2M3 17l1 1 2-2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M10 8h8M10 13h8M10 18h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </span>
        <div class="enCard__text">{text.items[5]}</div>
      </article>
    </div>
  </div>
</section>
