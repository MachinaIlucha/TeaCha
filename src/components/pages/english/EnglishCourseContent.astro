import { siteText } from "../../../data/siteText";
import beginnersIcon from "../../../assets/img/chinese/programs/teacha-chinese-course-beginners-icon.png";
import hskIcon from "../../../assets/img/chinese/programs/teacha-hsk-preparation-course-icon.png";
import kidsIcon from "../../../assets/img/chinese/programs/teacha-chinese-course-kids-teens-icon.png";
import businessIcon from "../../../assets/img/chinese/programs/teacha-business-chinese-course-icon.png";
import conversationIcon from "../../../assets/img/chinese/programs/teacha-conversational-chinese-course-icon.png";
import trialCtaLikeIcon from "../../../assets/img/forms/teacha-trial-lesson-cta-like-icon.png";

type CourseIconKey =
  | "beginners"
  | "hsk"
  | "kids"
  | "business"
  | "conversation";

type CourseHighlight = {
  value: string;
  label: string;
};

type CourseFeatureItem =
  | string
  | {
      summary: string;
      title?: string;
      text?: string;
      details?: string[];
    };

type CourseAbout = {
  title?: string;
  titleTop?: string;
  titleBottom?: string;
  lead: string;
  highlights?: CourseHighlight[];
  features?: CourseFeatureItem[];
};

type AudienceCard = {
  title: string;
  text: string;
  icon: CourseIconKey;
};

type CourseAudience = {
  title: string;
  cards?: AudienceCard[];
};

const { className = "", about, audience } = Astro.props as {
  className?: string;
  about: CourseAbout;
  audience: CourseAudience;
};

const base = import.meta.env.BASE_URL;
const sectionClass = ["cnCourse", className].filter(Boolean).join(" ");
const overviewText = siteText.sections.courseOverview;

const courseIcons = {
  beginners: beginnersIcon,
  hsk: hskIcon,
  kids: kidsIcon,
  business: businessIcon,
  conversation: conversationIcon,
} as const;

const fallbackAudienceIcons = [
  "beginners",
  "business",
  "conversation",
  "hsk",
] as const;

const headingMain = about.titleTop ?? about.title?.split(" ")[0] ?? "ПРО";
const headingAccent =
  about.titleBottom ?? about.title?.split(" ").slice(1).join(" ") ?? "КУРС";

const audienceCards =
  audience.cards ??
  [];

const splitFeatureText = (value: string) => {
  const colonIndex = value.indexOf(":");

  if (colonIndex === -1) {
    return { title: "", text: value };
  }

  return {
    title: value.slice(0, colonIndex + 1),
    text: value.slice(colonIndex + 1).trim(),
  };
};

const normalizeFeature = (item: CourseFeatureItem) => {
  const summary = typeof item === "string" ? item : item.summary;
  const directTitle = typeof item === "string" ? "" : item.title?.trim() ?? "";
  const directText = typeof item === "string" ? "" : item.text?.trim() ?? "";
  const details =
    typeof item === "string"
      ? []
      : item.details?.filter((detail) => detail.trim().length > 0) ?? [];
  const fallbackSplit = splitFeatureText(summary);

  return {
    summary,
    title: directTitle || fallbackSplit.title,
    text: directText || fallbackSplit.text || summary,
    details:
      details.length > 0
        ? details
        : [
            `Фокус цього блоку: ${summary}.`,
            "Опрацьовуємо тему на заняттях, у вправах і практиці з викладачем.",
          ],
  };
};
---

<section class={sectionClass} data-reveal="scroll">
  <div class="container">
    <header class="cnCourse__intro" data-reveal="scroll">
      <h2 class="cnCourse__heading" data-reveal-item="1">
        <span class="cnCourse__headingMain">{headingMain}</span>
        <span class="cnCourse__headingAccent">{headingAccent}</span>
      </h2>

      <p class="cnCourse__lead" data-reveal-item="2">{about.lead}</p>
    </header>

    <div class="cnCourse__surface" data-reveal-item="3">
      {
        about.highlights && about.highlights.length > 0 && (
          <div class="cnCourse__highlights">
            {about.highlights.map((item) => (
              <article class="cnCourse__highlight">
                <div class="cnCourse__highlightValue">{item.value}</div>
                <p class="cnCourse__highlightLabel">{item.label}</p>
              </article>
            ))}
          </div>
        )
      }

      <div class="cnCourse__programTop">
        <h3 class="cnCourse__sectionTitle">{overviewText.programTitle}</h3>
      </div>

      <ul class="cnCourse__programList">
        {(about.features ?? []).map((item) => {
          const featureItem = normalizeFeature(item);

          return (
            <li>
              <details class="cnCourse__programItem cnCourse__programItem--accordion">
                <summary class="cnCourse__programSummary">
                  <span class="cnCourse__programDot" aria-hidden="true"></span>
                  <div class="cnCourse__programText">
                    {featureItem.title && <strong>{featureItem.title}</strong>}
                    {featureItem.text && <span>{featureItem.text}</span>}
                  </div>

                  <span class="cnCourse__programToggle" aria-hidden="true"></span>
                </summary>

                <div class="cnCourse__programPanel">
                  <div class="cnCourse__programPanelInner">
                    <ul class="cnCourse__programDetails">
                      {featureItem.details.map((detail) => (
                        <li class="cnCourse__programDetail">{detail}</li>
                      ))}
                    </ul>
                  </div>
                </div>
              </details>
            </li>
          );
        })}
      </ul>

      <div class="cnCourse__actions">
        <button class="cnCourse__trial heroPill" type="button" data-open-modal>
          <span class="cnCourse__trialIcon" aria-hidden="true">
            <img
              src={trialCtaLikeIcon.src}
              alt="Іконка вподобайки для кнопки запису на пробний урок TeaCha"
              loading="lazy"
              decoding="async"
              width={trialCtaLikeIcon.width}
              height={trialCtaLikeIcon.height}
            />
          </span>
          <span>{overviewText.ctaLabel}</span>
          <span class="cnCourse__trialArrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
              <path
                d="M5 12h14M13 6l6 6-6 6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
        </button>

        <a class="cnCourse__ghostAction" href={`${base}${overviewText.pricesHref}`}>
          <span>{overviewText.pricesLabel}</span>
          <span class="cnCourse__ghostArrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
              <path
                d="M5 12h14M13 6l6 6-6 6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
        </a>
      </div>

      <div class="cnCourse__audience">
        <h3 class="cnCourse__sectionTitle cnCourse__sectionTitle--audience">
          {audience.title}
        </h3>

        <div class="cnCourse__audienceGrid">
          {
            audienceCards.map((card) => {
              const icon = courseIcons[card.icon];

              return (
                <article class="cnCourse__audienceCard">
                  <div class="cnCourse__audienceHead">
                    <img
                      class="cnCourse__audienceIcon"
                      src={icon.src}
                      alt=""
                      aria-hidden="true"
                      loading="lazy"
                      decoding="async"
                      width={icon.width}
                      height={icon.height}
                    />

                    <div class="cnCourse__audienceCopy">
                      <h4 class="cnCourse__audienceCardTitle">{card.title}</h4>
                      {card.text && <p class="cnCourse__audienceCardText">{card.text}</p>}
                    </div>
                  </div>
                </article>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const initEnglishCourseAccordions = () => {
    const accordionItems = document.querySelectorAll(".cnCourse__programItem--accordion");

    accordionItems.forEach((item) => {
      if (!(item instanceof HTMLDetailsElement) || item.dataset.enhanced === "true") {
        return;
      }

      const summary = item.querySelector(".cnCourse__programSummary");
      const panel = item.querySelector(".cnCourse__programPanel");

      if (!(summary instanceof HTMLElement) || !(panel instanceof HTMLElement)) {
        return;
      }

      item.dataset.enhanced = "true";

      let animation: Animation | null = null;

      const cleanup = (shouldStayOpen: boolean) => {
        if (animation) {
          animation.cancel();
          animation = null;
        }

        item.open = shouldStayOpen;
        panel.style.height = "";
        panel.style.opacity = "";
        panel.style.overflow = "";
      };

      const openPanel = () => {
        if (animation) {
          animation.cancel();
        }

        item.open = true;
        panel.style.overflow = "hidden";
        panel.style.height = "0px";
        panel.style.opacity = "0";

        requestAnimationFrame(() => {
          const endHeight = `${panel.scrollHeight}px`;

          animation = panel.animate(
            [
              { height: "0px", opacity: 0 },
              { height: endHeight, opacity: 1 },
            ],
            {
              duration: 280,
              easing: "cubic-bezier(0.22, 1, 0.36, 1)",
            },
          );

          panel.style.height = endHeight;
          panel.style.opacity = "1";

          animation.onfinish = () => cleanup(true);
          animation.oncancel = () => {
            animation = null;
          };
        });
      };

      const closePanel = () => {
        if (animation) {
          animation.cancel();
        }

        const startHeight = `${panel.offsetHeight}px`;

        panel.style.overflow = "hidden";
        panel.style.height = startHeight;
        panel.style.opacity = "1";

        requestAnimationFrame(() => {
          animation = panel.animate(
            [
              { height: startHeight, opacity: 1 },
              { height: "0px", opacity: 0 },
            ],
            {
              duration: 240,
              easing: "cubic-bezier(0.4, 0, 0.2, 1)",
            },
          );

          panel.style.height = "0px";
          panel.style.opacity = "0";

          animation.onfinish = () => cleanup(false);
          animation.oncancel = () => {
            animation = null;
          };
        });
      };

      summary.addEventListener("click", (event) => {
        event.preventDefault();

        if (item.open) {
          closePanel();
          return;
        }

        openPanel();
      });
    });
  };

  document.addEventListener("DOMContentLoaded", initEnglishCourseAccordions, { once: true });
  document.addEventListener("astro:page-load", initEnglishCourseAccordions);
</script>
