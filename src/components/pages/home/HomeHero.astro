---
/**
 * TeaCha website
 * Design & development: Ілля Пінчук Вадимович
 * © 2026. All rights reserved.
 */
const base = import.meta.env.BASE_URL;
const { className = "" } = Astro.props;
---

<section class={`hero ${className}`} id="school" data-reveal="load">
  <div class="container hero__grid">
    <div class="hero__left">
      <div class="hero__title" data-reveal-item="1">
        <div class="hero__titleLine">
          <span class="tea">TEA</span><span class="cha">CHA</span> -
        </div>
        <div class="hero__titleLine">
          ДВІ КУЛЬТУРИ В ОДНОМУ ПРОСТОРІ
        </div>
      </div>

      <p class="hero__subtitle hero__subtitle--big" data-reveal-item="2">
        Ми - центр <br />найпопулярніших мов у світі
      </p>

      <!-- кнопки языков ДОЛЖНЫ появляться раньше badge -->
      <div class="hero__modes" data-reveal-item="3">
        <a href={`${base}english`} class="heroLangBtn">Англійська</a>
        <a href={`${base}chinese`} class="heroLangBtn">Китайська</a>
      </div>

      <!-- DESKTOP badge (анимация через обертку) -->
      <div class="hero__chips hero__chips--desktop" data-reveal-item="6">
        <button class="badge badge--round" type="button" data-open-modal>
          <span>ХОЧУ<br />ПРОБНИЙ УРОК</span>
        </button>
      </div>
    </div>

    <div class="hero__right" data-reveal-item="4">
      <!-- MOBILE badge (анимация через обертку) -->
      <div class="hero__chips hero__chips--mobile" data-reveal-item="5">
        <button class="badge badge--round" type="button" data-open-modal>
          <span>ХОЧУ<br />ПРОБНИЙ УРОК</span>
        </button>
      </div>

      <div class="heroPhoto">
        <img
          class="heroPhoto__img"
          src={`${base}img/hero/home/home-hero-teacha-team.png`}
          alt="Фото викладачів"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
