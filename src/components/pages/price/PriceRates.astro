                </div>
              </div>
            </article>

            <article class="priceCard" role="listitem">
              <a class="priceCard__cta" href={contactHref}>ЗАПИСАТИСЬ</a>
              <div class="priceCard__cap">24 уроки</div>
              <div class="priceCard__split">
                <div class="priceCard__col">
                  <div class="priceCard__value" data-price="group.24.per">—</div>
                  <div class="priceCard__meta">1 урок</div>
                </div>
                <div class="priceCard__col priceCard__col--strong">
                  <div class="priceCard__value priceCard__value--strong" data-price="group.24.total">—</div>
                  <div class="priceCard__meta">24 уроки</div>
                </div>
              </div>
            </article>
          </div>
        </section>

        <section class="priceGroup" aria-label="Пробне заняття">
          <h3 class="priceGroup__title">Пробне заняття</h3>

          <div class="priceCards priceCards--single" role="list">
            <article class="priceCard" role="listitem">
              <a class="priceCard__cta" href={contactHref}>ЗАПИСАТИСЬ</a>
              <div class="priceCard__cap">Пробне</div>
              <div class="priceCard__single">
                <div class="priceCard__value" data-price="trial.1.total">—</div>
                <div class="priceCard__meta">1 заняття</div>
              </div>
            </article>
          </div>
        </section>
      </div>
    </div>
  </div>
</section>
