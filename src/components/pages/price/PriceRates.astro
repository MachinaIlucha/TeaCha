                  <div class="priceCard__meta">{priceText.lessons24Label}</div>
                </div>
              </div>
            </article>
          </div>
        </section>

        <section class="priceGroup" aria-label={priceText.groups[3].ariaLabel}>
          <h3 class="priceGroup__title">{priceText.groups[3].title}</h3>

          <div class="priceCards priceCards--single" role="list">
            <article class="priceCard" role="listitem">
              <a class="priceCard__cta" href={contactHref}>{priceText.cta}</a>
              <div class="priceCard__cap">{priceText.trialCardLabel}</div>
              <div class="priceCard__single">
                <div class="priceCard__value" data-price="trial.1.total">—</div>
                <div class="priceCard__meta">{priceText.trialLessonLabel}</div>
              </div>
            </article>
          </div>
        </section>
      </div>
    </div>
  </div>
</section>
