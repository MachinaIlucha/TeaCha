              <div class="priceCard__split">
                <div class="priceCard__col">
                  <div class="priceCard__value" data-price="pair.12.per">—</div>
                  <div class="priceCard__meta">{priceText.singleLessonLabel}</div>
                </div>
                <div class="priceCard__col priceCard__col--strong">
                  <div class="priceCard__value priceCard__value--strong" data-price="pair.12.total">—</div>
                  <div class="priceCard__meta">{priceText.lessons12Label}</div>
