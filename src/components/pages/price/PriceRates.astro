---
/**
 * TeaCha website
 * © 2026. All rights reserved.
 */
import { siteText } from "../../../data/siteText";

const { className = "" } = Astro.props;
const contactHref = "#start-lead";
const priceText = siteText.sections.priceRates;
---

<section class={`priceRates ${className}`} id="prices" data-prices>
  <div class="container priceRates__container">
    <div class="priceRates__inner">
      <p class="priceRates__hint" data-price-item="1">
        {priceText.hint}
      </p>

      <header
        class="sectionTitle sectionTitle--center sectionTitle--accentBottom sectionTitle--stamped"
        data-price-item="2"
      >
        <h2 class="sectionTitle__line sectionTitle__line--a">{priceText.titleTop}</h2>
        <div class="sectionTitle__line sectionTitle__line--b">{priceText.titleBottom}</div>
      </header>

      <div class="priceGroups" data-price-item="3" aria-label={priceText.groupsAria}>
        <section class="priceGroup" aria-label={priceText.groups[0].ariaLabel}>
          <h3 class="priceGroup__title">{priceText.groups[0].title}</h3>

          <div class="priceCards" role="list">
            <article class="priceCard" role="listitem">
              <a class="priceCard__cta" href={contactHref}>{priceText.cta}</a>
              <div class="priceCard__cap">{priceText.singleLessonLabel}</div>
              <div class="priceCard__single">
                <div class="priceCard__value" data-price="individual.1.total">—</div>
                <div class="priceCard__meta">{priceText.singleLessonLabel}</div>
              </div>
            </article>

            <article class="priceCard" role="listitem">
              <a class="priceCard__cta" href={contactHref}>{priceText.cta}</a>
              <div class="priceCard__cap">{priceText.lessons8Label}</div>
              <div class="priceCard__split">
                <div class="priceCard__col">
                  <div class="priceCard__value" data-price="individual.8.per">—</div>
                  <div class="priceCard__meta">{priceText.singleLessonLabel}</div>
                </div>
                <div class="priceCard__col priceCard__col--strong">
                  <div class="priceCard__value priceCard__value--strong" data-price="individual.8.total">—</div>
                  <div class="priceCard__meta">{priceText.lessons8Label}</div>
                </div>
              </div>
            </article>

            <article class="priceCard" role="listitem">
              <a class="priceCard__cta" href={contactHref}>{priceText.cta}</a>
              <div class="priceCard__cap">{priceText.lessons12Label}</div>
              <div class="priceCard__split">
                <div class="priceCard__col">
                  <div class="priceCard__value" data-price="individual.12.per">—</div>
                  <div class="priceCard__meta">{priceText.singleLessonLabel}</div>
                </div>
                <div class="priceCard__col priceCard__col--strong">
                  <div class="priceCard__value priceCard__value--strong" data-price="individual.12.total">—</div>
                  <div class="priceCard__meta">{priceText.lessons12Label}</div>
                </div>
              </div>
            </article>

            <article class="priceCard" role="listitem">
              <a class="priceCard__cta" href={contactHref}>{priceText.cta}</a>
              <div class="priceCard__cap">{priceText.lessons24Label}</div>
              <div class="priceCard__split">
                <div class="priceCard__col">
                  <div class="priceCard__value" data-price="individual.24.per">—</div>
                  <div class="priceCard__meta">{priceText.singleLessonLabel}</div>
                </div>
                <div class="priceCard__col priceCard__col--strong">
                  <div class="priceCard__value priceCard__value--strong" data-price="individual.24.total">—</div>
                  <div class="priceCard__meta">{priceText.lessons24Label}</div>
                </div>
              </div>
            </article>
          </div>
        </section>

        <section class="priceGroup" aria-label={priceText.groups[1].ariaLabel}>
          <h3 class="priceGroup__title">{priceText.groups[1].title}</h3>

          <div class="priceCards" role="list">
            <article class="priceCard" role="listitem">
              <a class="priceCard__cta" href={contactHref}>{priceText.cta}</a>
              <div class="priceCard__cap">{priceText.singleLessonLabel}</div>
