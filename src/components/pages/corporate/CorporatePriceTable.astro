 * Design & development: Ілля Пінчук Вадимович
 * © 2026. All rights reserved.
 */
import { siteText } from "../../../data/siteText";

const { className = "", sectionId = "prices" } = Astro.props;
const sectionClass = ["corpPrice", className].filter(Boolean).join(" ");
const contactHref = "#contacts";
const text = siteText.sections.corporatePrice;
const pricePlans = text.plans;
---

<section class={sectionClass} id={sectionId} data-reveal="scroll">
  <div class="container">
    <header
      class="sectionTitle sectionTitle--center sectionTitle--accentBottom"
      data-reveal="scroll"
    >
      <p class="corpPrice__hint" data-reveal-item="1">
        {text.hint}
      </p>
      <h2 class="sectionTitle__line sectionTitle__line--a" data-reveal-item="2">
        {text.titleTop}
      </h2>
      <div class="sectionTitle__line sectionTitle__line--b" data-reveal-item="3">
        <span class="corpPrice__titleBracket" aria-hidden="true">[</span>
        {text.titleBottom}<span class="corpPrice__titleBracket" aria-hidden="true"
          >]</span
        >
      </div>
    </header>

    <div class="corpPrice__panel" data-reveal-item="4">
      <div class="corpPrice__mobileList" role="list" aria-label={text.tableAria}>
        <div class="corpPrice__mobileMeta">
          <div class="corpPrice__stubTop">{text.stubTop}</div>
          <div class="corpPrice__stubBottom">{text.stubBottom}</div>
          <div class="corpPrice__mobileLabel">{text.mobileLabel}</div>
        </div>

        {
          pricePlans.map((plan) => (
            <article class="corpPrice__mobileCard" role="listitem">
              <h3 class="corpPrice__mobileLessons">{plan.lessons}</h3>
              <div class="corpPrice__mobilePrice">{plan.price}</div>
            </article>
          ))
        }
      </div>

      <div class="corpPrice__tableWrap" role="region" aria-label={text.tableAria}>
        <div class="corpPrice__table" role="table" aria-label={text.tableAria}>
          <div class="corpPrice__row corpPrice__row--head" role="row">
            <div class="corpPrice__cell corpPrice__cell--stub" role="columnheader">
              <div class="corpPrice__stubTop">{text.stubTop}</div>
              <div class="corpPrice__stubBottom">{text.stubBottom}</div>
            </div>
            {
              pricePlans.map((plan) => (
                <div class="corpPrice__cell" role="columnheader">{plan.lessons}</div>
              ))
            }
          </div>

          <div class="corpPrice__row" role="row">
            <div class="corpPrice__cell corpPrice__cell--rowhead" role="rowheader" set:html={text.rowLabel} />
            {
              pricePlans.map((plan) => (
                <div class="corpPrice__cell corpPrice__cell--price" role="cell">
                  <a class="corpPrice__cta" href={contactHref}>{text.cta}</a>
                  <div class="corpPrice__value">{plan.price}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div class="corpPrice__notes">
        {text.notes.map((note) => <div class="corpPrice__note">{note}</div>)}
      </div>
    </div>
  </div>
</section>
