---
/**
 * TeaCha website
 * © 2026. All rights reserved.
 */
const { base, className = "" } = Astro.props;
const sectionClass = ["cClients", className].filter(Boolean).join(" ");

const clients = [
  {
    src: `${base}img/corporate/clients/rooms8studio.svg`,
    alt: "Room 8 Studio logo",
    name: "Room 8 Studio",
    details: "розробка відеоігор, підтримка команд GameDev",
    href: "https://room8studio.com/",
  },
  {
    src: `${base}img/corporate/clients/snt_ukraine_logo.svg`,
    alt: "SNT Ukraine logo",
    name: "SNT Ukraine",
    details: "інтеграція телекомунікаційних та корпоративних IT-систем",
    href: "https://snt.ua/",
  },
  {
    src: `${base}img/corporate/clients/seediun_logo.png`,
    alt: "Seedium.io logo",
    name: "Seedium.io",
    details: "full-stack development, UI/UX, DevOps",
    href: "https://seedium.io/",
  },
  {
    src: `${base}img/corporate/clients/panorama.png`,
    alt: "Chevalier Panorama logo",
    name: "Chevalier Panorama / Chevalier Hotel",
    details: "готельний комплекс",
    href: "https://chevalier-panorama.com/",
  },
];
---

<section class={sectionClass} data-reveal="scroll">
  <div class="container">
    <header
      class="sectionTitle sectionTitle--center sectionTitle--accentBottom cClients__title"
      data-reveal-item="1"
    >
      <h2 class="sectionTitle__line sectionTitle__line--a">КОРПОРАТИВНІ</h2>
      <div class="sectionTitle__line sectionTitle__line--b">КЛІЄНТИ</div>
    </header>

    <div
      class="cClients__compact"
      data-reveal-item="2"
      aria-label="Компанії, з якими ми працюємо"
    >
      <span class="cClients__compactLabel">Компанії:</span>
      <div class="cClients__compactTrack">
        {
          clients.map((client) => (
            <a
              class="cClients__compactItem"
              href={client.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${client.name}: перейти на сайт`}
            >
              {client.name}
            </a>
          ))
        }
      </div>
    </div>

    <div class="cClients__grid" data-reveal-item="3">
      {
        clients.map((client) => (
          <a
            class="cClients__card"
            href={client.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${client.name}: перейти на сайт`}
          >
            <div class="cClients__logoWrap">
              <img
                class="cClients__logo"
                src={client.src}
                alt={client.alt}
                loading="lazy"
              />
            </div>
            <p class="cClients__text">
              <strong>{client.name}</strong>{" "}
              <span class="cClients__details">({client.details})</span>
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>
