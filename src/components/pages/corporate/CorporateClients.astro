import { siteText } from "../../../data/siteText";
import { resolveAssetPath } from "../../../data/assetMap";

const { className = "" } = Astro.props;
const sectionClass = ["cClients", className].filter(Boolean).join(" ");
const text = siteText.sections.corporateClients;
const mobileLoopCopies = [0, 1, 2];

const clients = text.clients.map((client) => ({
  ...client,
  src: resolveAssetPath(client.logo),
  useNativeTone: client.logo.toLowerCase().includes("seediun_logo.png"),
}));
---

<section class={sectionClass} data-reveal="scroll">
  <div class="container">
    <header
      class="sectionTitle sectionTitle--center sectionTitle--accentBottom cClients__title"
      data-reveal-item="1"
    >
      <h2 class="sectionTitle__line sectionTitle__line--a">{text.titleTop}</h2>
      <div class="sectionTitle__line sectionTitle__line--b">{text.titleBottom}</div>
    </header>

    <div
      class="cClients__mobileRail"
      data-reveal-item="2"
      aria-label={text.companiesAria}
    >
      <div class="cClients__mobileTrack" data-loop-track data-loop-copies="3">
        {
          mobileLoopCopies.flatMap((copyIndex) =>
            clients.map((client) => (
              <a
                class="cClients__mobileCard"
                href={client.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${client.name}: ${text.visitLabel}`}
                aria-hidden={copyIndex === 1 ? undefined : "true"}
                tabindex={copyIndex === 1 ? undefined : "-1"}
              >
              <img
                class={`cClients__mobileLogo${client.useNativeTone ? " cClients__mobileLogo--native" : ""}`}
                src={client.src}
                alt={client.alt}
                loading="lazy"
              />
              </a>
            ))
          )
        }
      </div>
    </div>

    <div class="cClients__grid" data-reveal-item="3">
      {
        clients.map((client) => (
          <a
            class="cClients__card"
            href={client.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${client.name}: ${text.visitLabel}`}
          >
            <div class="cClients__logoWrap">
              <img
                class="cClients__logo"
                src={client.src}
                alt={client.alt}
                loading="lazy"
              />
            </div>
            <p class="cClients__text">
              <strong>{client.name}</strong>{" "}
              <span class="cClients__details">({client.details})</span>
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const initCircularClientScroll = () => {
      const tracks = document.querySelectorAll(".cClients__mobileTrack[data-loop-track]");
      tracks.forEach((track) => {
        if (!(track instanceof HTMLElement) || track.dataset.loopReady === "true") {
          return;
        }

        const copies = Number(track.dataset.loopCopies || "3");
        if (!Number.isFinite(copies) || copies < 2) {
          return;
        }

        let segmentWidth = 0;
        let isRepositioning = false;

        const getStartPosition = () => {
          const cards = track.querySelectorAll(".cClients__mobileCard");
          const firstCard = cards[0];

          if (!(firstCard instanceof HTMLElement)) {
            return segmentWidth;
          }

          const centerInset = Math.max(0, (track.clientWidth - firstCard.offsetWidth) / 2);
          return segmentWidth - centerInset;
        };

        const recalc = (forceStart = false) => {
          const totalWidth = track.scrollWidth;
          segmentWidth = totalWidth / copies;

          if (!Number.isFinite(segmentWidth) || segmentWidth <= 0) {
            return;
          }

          const startPosition = getStartPosition();
          if (forceStart) {
            track.scrollLeft = startPosition;
            return;
          }

          if (track.scrollLeft < segmentWidth * 0.5 || track.scrollLeft > segmentWidth * 1.5) {
            track.scrollLeft = startPosition;
          }
        };

        const onScroll = () => {
          if (!segmentWidth || isRepositioning) {
            return;
          }

          const minEdge = segmentWidth * 0.25;
          const maxEdge = segmentWidth * 1.75;

          if (track.scrollLeft <= minEdge) {
            isRepositioning = true;
            track.scrollLeft += segmentWidth;
            isRepositioning = false;
            return;
          }

          if (track.scrollLeft >= maxEdge) {
            isRepositioning = true;
            track.scrollLeft -= segmentWidth;
            isRepositioning = false;
          }
        };

        recalc(true);
        requestAnimationFrame(() => recalc(true));
        track.addEventListener("scroll", onScroll, { passive: true });

        const resizeObserver = new ResizeObserver(() => recalc());
        resizeObserver.observe(track);
        track.dataset.loopReady = "true";
      });
    };

    initCircularClientScroll();
    document.addEventListener("astro:page-load", initCircularClientScroll);
  })();
</script>
