---
/**
 * TeaCha website
 * © 2026. All rights reserved.
 */
import { siteText } from "../../../data/siteText";

const { base, className = "" } = Astro.props;
const sectionClass = ["cClients", className].filter(Boolean).join(" ");
const text = siteText.sections.corporateClients;

const clients = text.clients.map((client) => ({
  ...client,
  src: `${base}${client.logo}`,
}));
---

<section class={sectionClass} data-reveal="scroll">
  <div class="container">
    <header
      class="sectionTitle sectionTitle--center sectionTitle--accentBottom cClients__title"
      data-reveal-item="1"
    >
      <h2 class="sectionTitle__line sectionTitle__line--a">{text.titleTop}</h2>
      <div class="sectionTitle__line sectionTitle__line--b">{text.titleBottom}</div>
    </header>

    <div
      class="cClients__compact"
      data-reveal-item="2"
      aria-label={text.companiesAria}
    >
      <span class="cClients__compactLabel">{text.compactLabel}</span>
      <div class="cClients__compactTrack">
        {
          clients.map((client) => (
            <a
              class="cClients__compactItem"
              href={client.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${client.name}: ${text.visitLabel}`}
            >
              {client.name}
            </a>
          ))
        }
      </div>
    </div>

    <div class="cClients__grid" data-reveal-item="3">
      {
        clients.map((client) => (
          <a
            class="cClients__card"
            href={client.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${client.name}: ${text.visitLabel}`}
          >
            <div class="cClients__logoWrap">
              <img
                class="cClients__logo"
                src={client.src}
                alt={client.alt}
                loading="lazy"
              />
            </div>
            <p class="cClients__text">
              <strong>{client.name}</strong>{" "}
              <span class="cClients__details">({client.details})</span>
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>
