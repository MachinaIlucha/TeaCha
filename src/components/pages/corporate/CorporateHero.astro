import LanguageHero from "../../sections/LanguageHero.astro";
import { siteText } from "../../../data/siteText";

const { base, className = "" } = Astro.props;
const heroText = siteText.sections.corporateHero;
---

<LanguageHero
  base={base}
  className={className}
  imgSrc={`${base}img/hero/corporate/corporate-hero-team.webp`}
  imgAlt={heroText.imageAlt}
  imgLoading="eager"
  imgFetchpriority="high"
  titleParts={heroText.titleParts}
  subtitle={heroText.subtitle}
/>
