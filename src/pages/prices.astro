import BaseLayout from "../layouts/BaseLayout.astro";
import PriceRates from "../components/pages/price/PriceRates.astro";
import CorporatePriceTable from "../components/pages/corporate/CorporatePriceTable.astro";
import Faq from "../components/sections/Faq.astro";
import { siteText } from "../data/siteText";

const base = import.meta.env.BASE_URL;
const pageText = siteText.pages.prices;
---

<BaseLayout
  title={pageText.title}
  description={pageText.description}
  ogImage="/img/hero/home/home-hero-background.jpg"
  breadcrumbs={[{ name: pageText.breadcrumb, href: "/prices/" }]}
  bodyClass="page-price"
>
  <section class="sectionShell section--a landingLinks" data-reveal="scroll">
    <div class="container">
      <h1 class="sectionTitle sectionTitle--center sectionTitle--accentBottom landingLinks__title landingLinks__title--price">
        <span class="sectionTitle__line sectionTitle__line--a" data-reveal-item="1">{pageText.headingTop}</span>
        <span class="sectionTitle__line sectionTitle__line--b" data-reveal-item="2">{pageText.headingBottom}</span>
      </h1>
      <p class="landingLinks__lead landingLinks__lead--price" data-reveal-item="3">
        {pageText.lead}
      </p>
    </div>
  </section>

  <PriceRates base={base} className="sectionShell section--a" />
  <CorporatePriceTable className="sectionShell section--b" sectionId="corporate-prices" />
  <Faq className="sectionShell section--b" />
</BaseLayout>
