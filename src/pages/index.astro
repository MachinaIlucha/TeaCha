import BaseLayout from "../layouts/BaseLayout.astro";
import HomeHero from "../components/pages/home/HomeHero.astro";
import Reviews from "../components/sections/Reviews.astro";
import Facts from "../components/sections/Facts.astro";
import Teachers from "../components/sections/Teachers.astro";
import Process from "../components/sections/Process.astro";
import PriceRates from "../components/pages/price/PriceRates.astro";
import Faq from "../components/sections/Faq.astro";
import TestBanner from "../components/sections/TestBanner.astro";
import { siteText } from "../data/siteText";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={siteText.pages.index.title}
  description={siteText.pages.index.description}
  ogImage="/img/hero/home/home-hero-background.jpg"
>
  <HomeHero className="sectionShell section--a" />

  <Teachers className="sectionShell section--b" />
  <Facts className="sectionShell section--a" />
  <TestBanner className="section--a" />
  <section class="processDivider" aria-hidden="true">
    <div class="processDivider__band"></div>
  </section>
  <Process className="sectionShell section--b" />
  <PriceRates base={base} className="sectionShell section--a" />
  <Reviews className="sectionShell section--b section--ink" />
  <Faq className="sectionShell section--a" />
</BaseLayout>
