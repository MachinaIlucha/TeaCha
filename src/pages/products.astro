---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout bodyClass="page--products">
  <section class="productsPage sectionShell section--b section--ink">
    <div class="container">
      <header class="productsPage__head">
        <span class="handNote handNote--light">Крамниця TeaCha</span>
        <h1 class="sectionTitle sectionTitle--inline sectionTitle--center">
          <span class="sectionTitle__line sectionTitle__line--a">НАША</span>
          <span class="sectionTitle__line sectionTitle__line--b">ПРОДУКЦІЯ</span>
        </h1>
      </header>

      <div class="productsGrid">
        <article class="productCard">
          <div class="productCard__media">
            <img class="productCard__img" src={`${base}img/books-on-shelf.png`} alt="Стартова картка TeaCha A1" loading="lazy" />
          </div>
          <h3 class="productCard__name">Стартова картка TeaCha A1</h3>
          <p class="productCard__price">390 грн</p>
        </article>

        <article class="productCard">
          <div class="productCard__media">
            <img class="productCard__img" src={`${base}img/chinese-scroll.png`} alt="Робочий зошит TeaCha A2" loading="lazy" />
          </div>
          <h3 class="productCard__name">Робочий зошит TeaCha A2</h3>
          <p class="productCard__price">520 грн</p>
        </article>

        <article class="productCard">
          <div class="productCard__media">
            <img class="productCard__img" src={`${base}img/doodle-hand.png`} alt="Набір карток TeaCha" loading="lazy" />
          </div>
          <h3 class="productCard__name">Набір карток TeaCha</h3>
          <p class="productCard__price">340 грн</p>
        </article>

        <article class="productCard">
          <div class="productCard__media">
            <img class="productCard__img" src={`${base}img/hero-portrait.jpg`} alt="Плакат Chinese Basics" loading="lazy" />
          </div>
          <h3 class="productCard__name">Плакат Chinese Basics</h3>
          <p class="productCard__price">290 грн</p>
        </article>

        <article class="productCard">
          <div class="productCard__media">
            <img class="productCard__img" src={`${base}img/teachers.png`} alt="Workbook Speaking Pack" loading="lazy" />
          </div>
          <h3 class="productCard__name">Workbook Speaking Pack</h3>
          <p class="productCard__price">610 грн</p>
        </article>

        <article class="productCard">
          <div class="productCard__media">
            <img class="productCard__img" src={`${base}img/icon-handwrite-black.png`} alt="Каліграфічний набір" loading="lazy" />
          </div>
          <h3 class="productCard__name">Каліграфічний набір</h3>
          <p class="productCard__price">450 грн</p>
        </article>

        <article class="productCard">
          <div class="productCard__media">
            <img class="productCard__img" src={`${base}img/icon-smile.png`} alt="Набір мотиваційних стікерів" loading="lazy" />
          </div>
          <h3 class="productCard__name">Набір мотиваційних стікерів</h3>
          <p class="productCard__price">190 грн</p>
        </article>

        <article class="productCard">
          <div class="productCard__media">
            <img class="productCard__img" src={`${base}img/messenger-sticker.png`} alt="Messenger Pack TeaCha" loading="lazy" />
          </div>
          <h3 class="productCard__name">Messenger Pack TeaCha</h3>
          <p class="productCard__price">230 грн</p>
        </article>

        <article class="productCard">
          <div class="productCard__media">
            <img class="productCard__img" src={`${base}img/chinese-brush-stroke-round.png`} alt="Міні набір символів Hanzi" loading="lazy" />
          </div>
          <h3 class="productCard__name">Міні набір символів Hanzi</h3>
          <p class="productCard__price">310 грн</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
