---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Продукція TeaCha"
  description="Фірмова продукція TeaCha: футболки та наліпки."
  ogImage="/img/products/teacha-first-tshirt-front.jpg"
  breadcrumbs={[{ name: "Продукція", href: "/products/" }]}
  bodyClass="page--products"
>
  <section class="productsPage sectionShell section--b section--ink">
    <div class="container">
      <header class="productsPage__head">
        <h1 class="sectionTitle sectionTitle--inline sectionTitle--center">
          <span class="sectionTitle__line sectionTitle__line--a">НАША</span>
          <span class="sectionTitle__line sectionTitle__line--b">ПРОДУКЦІЯ</span>
        </h1>
      </header>

      <div class="productsGrid">
        <article class="productCard">
          <div
            class="productCard__media productCard__media--scroll"
            aria-label="Футболка Learning English energy: фото 1 і фото 2"
          >
            <div class="productCard__mediaTrack">
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-first-tshirt-front.webp`}
                alt="Футболка Learning English energy TeaCha, фото 1"
                loading="lazy"
                decoding="async"
                width="1181"
                height="1181"
              />
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-first-tshirt-back.webp`}
                alt="Футболка Learning English energy TeaCha, фото 2"
                loading="lazy"
                decoding="async"
                width="1181"
                height="1181"
              />
            </div>
          </div>
          <h3 class="productCard__name">Футболка Learning English energy</h3>
          <p class="productCard__price">750 грн</p>
        </article>

        <article class="productCard">
          <div
            class="productCard__media productCard__media--scroll"
            aria-label="Футболка English learning therapy: фото 1 і фото 2"
          >
            <div class="productCard__mediaTrack">
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-second-tshirt-front.webp`}
                alt="Футболка English learning therapy TeaCha, фото 1"
                loading="lazy"
                decoding="async"
                width="1181"
                height="1181"
              />
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-second-tshirt-back.webp`}
                alt="Футболка English learning therapy TeaCha, фото 2"
                loading="lazy"
                decoding="async"
                width="1181"
                height="1181"
              />
            </div>
          </div>
          <h3 class="productCard__name">Футболка English learning therapy</h3>
          <p class="productCard__price">750 грн</p>
        </article>

        <article class="productCard productCard--wide">
          <div
            class="productCard__media productCard__media--scroll"
            aria-label="Наліпки TeaCha: фото 1 і фото 2"
          >
            <div class="productCard__mediaTrack">
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-stickers-pack.webp`}
                alt="Наліпки TeaCha, фото 1"
                loading="lazy"
                decoding="async"
                width="913"
                height="1280"
              />
              <img
                class="productCard__img productCard__img--stickersAlt"
                src={`${base}img/products/teacha-stickers-pack-alt.webp`}
                alt="Наліпки TeaCha, фото 2"
                loading="lazy"
                decoding="async"
                width="1659"
                height="2488"
              />
            </div>
          </div>
          <h3 class="productCard__name">Наліпки</h3>
          <p class="productCard__price">100 грн</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
