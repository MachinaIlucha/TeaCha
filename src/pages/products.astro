---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteText } from "../data/siteText";

const base = import.meta.env.BASE_URL;
const pageText = siteText.pages.products;
---

<BaseLayout
  title={pageText.title}
  description={pageText.description}
  ogImage="/img/products/teacha-first-tshirt-front.jpg"
  breadcrumbs={[{ name: pageText.breadcrumb, href: "/products/" }]}
  bodyClass="page--products"
>
  <section class="productsPage sectionShell section--b section--ink">
    <div class="container">
      <header class="productsPage__head" data-reveal="scroll">
        <h1 class="sectionTitle sectionTitle--inline sectionTitle--center">
          <span class="sectionTitle__line sectionTitle__line--a" data-reveal-item="1">{pageText.headingTop}</span>
          <span class="sectionTitle__line sectionTitle__line--b" data-reveal-item="2">{pageText.headingBottom}</span>
        </h1>
      </header>

      <div class="productsGrid">
        <article class="productCard" data-reveal="scroll">
          <div
            class="productCard__media productCard__media--scroll"
            data-reveal-item="1"
            aria-label={pageText.items[0].galleryAria}
          >
            <div class="productCard__mediaTrack">
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-first-tshirt-front.webp`}
                alt={pageText.items[0].alt1}
                loading="lazy"
                decoding="async"
                width="1181"
                height="1181"
              />
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-first-tshirt-back.webp`}
                alt={pageText.items[0].alt2}
                loading="lazy"
                decoding="async"
                width="1181"
                height="1181"
              />
            </div>
          </div>
          <h3 class="productCard__name" data-reveal-item="2">{pageText.items[0].name}</h3>
          <p class="productCard__price" data-reveal-item="3">{pageText.items[0].price}</p>
        </article>

        <article class="productCard" data-reveal="scroll">
          <div
            class="productCard__media productCard__media--scroll"
            data-reveal-item="1"
            aria-label={pageText.items[1].galleryAria}
          >
            <div class="productCard__mediaTrack">
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-second-tshirt-front.webp`}
                alt={pageText.items[1].alt1}
                loading="lazy"
                decoding="async"
                width="1181"
                height="1181"
              />
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-second-tshirt-back.webp`}
                alt={pageText.items[1].alt2}
                loading="lazy"
                decoding="async"
                width="1181"
                height="1181"
              />
            </div>
          </div>
          <h3 class="productCard__name" data-reveal-item="2">{pageText.items[1].name}</h3>
          <p class="productCard__price" data-reveal-item="3">{pageText.items[1].price}</p>
        </article>

        <article class="productCard productCard--wide" data-reveal="scroll">
          <div
            class="productCard__media productCard__media--scroll"
            data-reveal-item="1"
            aria-label={pageText.items[2].galleryAria}
          >
            <div class="productCard__mediaTrack">
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-stickers-pack.webp`}
                alt={pageText.items[2].alt1}
                loading="lazy"
                decoding="async"
                width="913"
                height="1280"
              />
              <img
                class="productCard__img productCard__img--stickersAlt"
                src={`${base}img/products/teacha-stickers-pack-alt.webp`}
                alt={pageText.items[2].alt2}
                loading="lazy"
                decoding="async"
                width="1659"
                height="2488"
              />
            </div>
          </div>
          <h3 class="productCard__name" data-reveal-item="2">{pageText.items[2].name}</h3>
          <p class="productCard__price" data-reveal-item="3">{pageText.items[2].price}</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
