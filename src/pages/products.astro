---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout bodyClass="page--products">
  <section class="productsPage sectionShell section--b section--ink">
    <div class="container">
      <header class="productsPage__head">
        <h1 class="sectionTitle sectionTitle--inline sectionTitle--center">
          <span class="sectionTitle__line sectionTitle__line--a">НАША</span>
          <span class="sectionTitle__line sectionTitle__line--b">ПРОДУКЦІЯ</span>
        </h1>
      </header>

      <div class="productsGrid">
        <article class="productCard">
          <div
            class="productCard__media productCard__media--scroll"
            aria-label="Перша футболка: фото 1 і фото 2"
          >
            <div class="productCard__mediaTrack">
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-first-tshirt-front.jpg`}
                alt="Перша футболка TeaCha, фото 1"
                loading="lazy"
              />
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-first-tshirt-back.jpg`}
                alt="Перша футболка TeaCha, фото 2"
                loading="lazy"
              />
            </div>
          </div>
          <h3 class="productCard__name">Перша футболка</h3>
          <p class="productCard__price">750 грн</p>
        </article>

        <article class="productCard">
          <div
            class="productCard__media productCard__media--scroll"
            aria-label="Друга футболка: фото 1 і фото 2"
          >
            <div class="productCard__mediaTrack">
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-second-tshirt-front.jpg`}
                alt="Друга футболка TeaCha, фото 1"
                loading="lazy"
              />
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-second-tshirt-back.jpg`}
                alt="Друга футболка TeaCha, фото 2"
                loading="lazy"
              />
            </div>
          </div>
          <h3 class="productCard__name">Друга футболка</h3>
          <p class="productCard__price">750 грн</p>
        </article>

        <article class="productCard productCard--wide">
          <div
            class="productCard__media productCard__media--scroll"
            aria-label="Наліпки TeaCha: фото 1 і фото 2"
          >
            <div class="productCard__mediaTrack">
              <img
                class="productCard__img"
                src={`${base}img/products/teacha-stickers-pack.jpg`}
                alt="Наліпки TeaCha, фото 1"
                loading="lazy"
              />
              <img
                class="productCard__img productCard__img--stickersAlt"
                src={`${base}img/products/teacha-stickers-pack-alt.jpg`}
                alt="Наліпки TeaCha, фото 2"
                loading="lazy"
              />
            </div>
          </div>
          <h3 class="productCard__name">Наліпки</h3>
          <p class="productCard__price">100 грн</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
