---
/**
 * TeaCha website
 * Custom 404 page
 * © 2026. All rights reserved.
 */

import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Сторінку не знайдено (404)"
  description="Сторінка, яку ви шукаєте, не існує. Поверніться на головну TeaCha або оберіть напрям навчання."
  canonical="/404/"
  ogImage="/img/hero/home/home-hero-background.jpg"
  bodyClass="page-404"
  noindex={true}
>
  <section class="notFound sectionShell section--b" data-reveal="load">
    <div class="container notFound__wrap">
      <p class="notFound__code" data-reveal-item="1">404</p>
      <h1 class="notFound__title" data-reveal-item="2">Сторінку не знайдено</h1>
      <p class="notFound__text" data-reveal-item="3">
        Перевірте адресу або скористайтеся навігацією нижче, щоб продовжити навчання з TeaCha.
      </p>

      <div class="notFound__actions" data-reveal-item="4">
        <a class="pill notFound__btn notFound__btn--solid" href={base}>На головну</a>
        <a class="pill notFound__btn" href={`${base}english`}>Англійська</a>
        <a class="pill notFound__btn" href={`${base}chinese`}>Китайська</a>
        <a class="pill notFound__btn" href={`${base}prices`}>Ціни</a>
      </div>
    </div>
  </section>
</BaseLayout>
