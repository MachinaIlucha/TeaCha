import BaseLayout from "../layouts/BaseLayout.astro";

import LanguageHero from "../components/sections/LanguageHero.astro";
import EnglishWhy from "../components/pages/english/EnglishWhy.astro";
import EnglishFormat from "../components/pages/english/EnglishFormat.astro";

import Process from "../components/sections/Process.astro";
import PriceRates from "../components/pages/price/PriceRates.astro";
import Reviews from "../components/sections/Reviews.astro";
import Faq from "../components/sections/Faq.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Англійська" reveal={true} bodyClass="page-english">
  <LanguageHero
    base={base}
    className="sectionShell section--a"
    titleParts={[
      { text: "АНГЛІЙСЬКА, ", accent: true },
      { text: "ЯКА" },
      { br: true },
      { text: "ВІДКРИЄ ДВЕРІ" },
      { br: true },
      { text: "ДО НОВИХ" },
      { br: true },
      { text: "МОЖЛИВ", accent: true },
      { text: "ОСТЕЙ" },
    ]}
    subtitle="Онлайн та офлайн у Києві • індивідуальний план • чітка структура уроків"
  />

  <EnglishWhy className="sectionShell section--b" />

  <Process className="sectionShell section--a" />

  <EnglishFormat base={base} className="sectionShell section--b" />

  <PriceRates base={base} className="sectionShell section--a" />

  <Reviews className="sectionShell section--b section--ink" />

  <Faq className="sectionShell section--a" />
</BaseLayout>
