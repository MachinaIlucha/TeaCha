 * © 2026. All rights reserved.
 */

import BaseLayout from "../layouts/BaseLayout.astro";

import LanguageHero from "../components/sections/LanguageHero.astro";
import ChineseWhy from "../components/pages/chinese/ChineseWhy.astro";
import ChineseFormat from "../components/pages/chinese/ChineseFormat.astro";

import Process from "../components/sections/Process.astro";
import PriceRates from "../components/pages/price/PriceRates.astro";
import Reviews from "../components/sections/Reviews.astro";
import Faq from "../components/sections/Faq.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Курси китайської мови"
  description="Курси китайської в TeaCha: індивідуальний план, практика розмовної мови, онлайн та офлайн у Києві."
  ogImage="/img/hero/chinese/chinese-language-hero.jpg"
  breadcrumbs={[{ name: "Курси китайської", href: "/chinese/" }]}
  bodyClass="page-chinese"
>
  <LanguageHero
    base={base}
    className="sectionShell section--a"
    imgSrc={`${base}img/hero/chinese/chinese-language-hero.webp`}
    imgAlt="Заняття з китайської мови в TeaCha"
    imgLoading="eager"
    imgFetchpriority="high"
    titleParts={[
      { text: "ПОЧНИ" },
      { br: true },
      { text: "ВИВЧАТИ" },
      { br: true },
      { text: "МОВУ" },
      { br: true },
      { text: "ДЛЯ НОВИХ" },
      { br: true },
      { text: "МОЖЛИВОСТЕЙ", accent: true },
    ]}
    subtitle="Онлайн та офлайн у Києві • Індивідуальний план • Чітка структура уроків"
  />

  <ChineseWhy className="sectionShell section--b" />
  <Process className="sectionShell section--a" />
  <ChineseFormat className="sectionShell section--b" />

  <PriceRates base={base} className="sectionShell section--a" />
  <Reviews className="sectionShell section--b section--ink" />
  <Faq className="sectionShell section--a" />
</BaseLayout>
